{
  "$defs": {
    "PatchOperation": {
      "additionalProperties": false,
      "properties": {
        "op": {
          "enum": [
            "add",
            "update",
            "remove",
            "move"
          ],
          "title": "Op",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "op",
        "path"
      ],
      "title": "PatchOperation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "user_intent": {
      "minLength": 1,
      "title": "User Intent",
      "type": "string"
    },
    "affected_objects": {
      "items": {
        "type": "string"
      },
      "title": "Affected Objects",
      "type": "array"
    },
    "operations": {
      "items": {
        "$ref": "#/$defs/PatchOperation"
      },
      "title": "Operations",
      "type": "array"
    },
    "impact_scope": {
      "enum": [
        "local",
        "sheet",
        "board",
        "global"
      ],
      "title": "Impact Scope",
      "type": "string"
    },
    "requires_confirmation": {
      "title": "Requires Confirmation",
      "type": "boolean"
    }
  },
  "required": [
    "user_intent",
    "impact_scope",
    "requires_confirmation"
  ],
  "title": "PatchPlan",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traceagent.dev/schemas/canonical/patch-plan.schema.json"
}
