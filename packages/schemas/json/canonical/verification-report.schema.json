{
  "$defs": {
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object",
          "properties": {
            "severity": {
              "$ref": "#/$defs/Severity"
            },
            "check": {
              "type": "string"
            },
            "source_kind": {
              "type": "string",
              "enum": [
                "formal",
                "heuristic"
              ]
            },
            "plain_english": {
              "type": "string"
            },
            "probable_cause": {
              "type": "string"
            },
            "affected_nets": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "affected_components": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "suggested_fixes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "evidence": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "CheckSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "status",
        "tool",
        "severity",
        "finding_count"
      ]
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "tool": {
      "minLength": 1,
      "title": "Tool",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/Severity"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "affected_objects": {
      "items": {
        "type": "string"
      },
      "title": "Affected Objects",
      "type": "array"
    },
    "suggested_fixes": {
      "items": {
        "type": "string"
      },
      "title": "Suggested Fixes",
      "type": "array"
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/CheckSummary"
      }
    }
  },
  "required": [
    "tool",
    "severity"
  ],
  "title": "VerificationReport",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traceagent.dev/schemas/canonical/verification-report.schema.json"
}
