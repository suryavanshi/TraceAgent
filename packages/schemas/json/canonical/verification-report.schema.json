{
  "$defs": {
    "Finding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "Finding",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "tool": {
      "minLength": 1,
      "title": "Tool",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/Severity"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "affected_objects": {
      "items": {
        "type": "string"
      },
      "title": "Affected Objects",
      "type": "array"
    },
    "suggested_fixes": {
      "items": {
        "type": "string"
      },
      "title": "Suggested Fixes",
      "type": "array"
    }
  },
  "required": [
    "tool",
    "severity"
  ],
  "title": "VerificationReport",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traceagent.dev/schemas/canonical/verification-report.schema.json"
}
